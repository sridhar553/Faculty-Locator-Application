generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Faculty {
  id                     String  @id @unique
  name                   String?
  department             String?
  subject                String?
  timetableLocation      String?
  password               String?
  role                   String? @default("faculty")
  
  // Flattened liveStatus fields
  liveStatusAvailability String?
  liveStatusLocation     String?
  liveStatusUpdatedAt    String?
}

model SystemConfig {
  key       String   @id @unique
  value     Json?
  updatedBy String?
  updatedAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  facultyId   String?
  facultyName String?
  action      String?
  details     Json?
  timestamp   DateTime @default(now())
}
